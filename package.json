{
  "name": "ctbz",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "worker:dev": "pnpm build && wrangler dev",
    "worker:deploy": "pnpm build && wrangler deploy",
    "worker:dry-run": "pnpm build && wrangler deploy --dry-run",
    "a2mcp:dev": "wrangler dev --config wrangler.a2mcp.jsonc",
    "a2mcp:deploy": "wrangler deploy --config wrangler.a2mcp.jsonc",
    "a2mcp:dry-run": "wrangler deploy --dry-run --config wrangler.a2mcp.jsonc",
    "a2mcp:migrations:apply:local": "wrangler d1 migrations apply ctbz-a2mcp --local --config wrangler.a2mcp.jsonc",
    "a2mcp:migrations:apply": "wrangler d1 migrations apply ctbz-a2mcp --remote --config wrangler.a2mcp.jsonc"
  },
  "dependencies": {
    "@filoz/synapse-sdk": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@okxweb3/x402-core": "^0.1.0",
    "@okxweb3/x402-evm": "^0.2.1",
    "@okxweb3/x402-hono": "^0.1.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@reown/appkit": "^1.8.21",
    "@reown/appkit-adapter-wagmi": "^1.8.21",
    "@tanstack/react-query": "^5.101.2",
    "animejs": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "hono": "^4.12.28",
    "lucide-react": "^1.22.0",
    "ogl": "^1.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.54.6",
    "wagmi": "^3.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@types/animejs": "^3.1.13",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
